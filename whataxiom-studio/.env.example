# ============================================================================
# WhatAxiom Studio — environment configuration
# Copy this file to `.env` (in the repo root OR in server/) and fill in keys.
# NEVER commit your real .env file.
# ============================================================================

# ---- Server ----
PORT=4000
# Comma-separated list of allowed CORS origins for the web client.
CLIENT_ORIGIN=http://localhost:5173

# ---- Script generation (Anthropic Claude) ----
ANTHROPIC_API_KEY=
# Model used to write the frame-by-frame narration script.
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ---- Image generation ----
# Which text-to-image provider to use: "replicate" | "fal" | "openai"
IMAGE_PROVIDER=replicate

# Replicate (Flux). Get a token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_MODEL=black-forest-labs/flux-1.1-pro

# Fal.ai (Flux). https://fal.ai/dashboard/keys
FAL_KEY=
FAL_MODEL=fal-ai/flux/dev

# OpenAI images (DALL·E / gpt-image-1)
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# ---- Text-to-speech (optional narration track) ----
# Which TTS provider to use: "elevenlabs" | "openai" | "none"
TTS_PROVIDER=none

# ElevenLabs. https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# OpenAI TTS (reuses OPENAI_API_KEY above)
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=onyx
